[gd_scene load_steps=3 format=3 uid="uid://uil6r6smfr7w"]

[ext_resource type="Script" path="res://scripts/finance_help_popup.gd" id="1_script"]

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_bg"]
bg_color = Color(0.15, 0.15, 0.2, 0.95)
corner_radius_top_left = 15
corner_radius_top_right = 15
corner_radius_bottom_right = 15
corner_radius_bottom_left = 15
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
border_color = Color(0.4, 0.6, 1, 1)

[node name="FinanceHelpPopup" type="CanvasLayer"]
process_mode = 3
script = ExtResource("1_script")

[node name="Background" type="ColorRect" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0, 0, 0, 0.5)

[node name="Panel" type="PanelContainer" parent="."]
custom_minimum_size = Vector2(600, 450)
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -300.0
offset_top = -225.0
offset_right = 300.0
offset_bottom = 225.0
grow_horizontal = 2
grow_vertical = 2
theme_override_styles/panel = SubResource("StyleBoxFlat_bg")

[node name="VBox" type="VBoxContainer" parent="Panel"]
layout_mode = 2
theme_override_constants/separation = 20

[node name="Header" type="Label" parent="Panel/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 36
text = "Finance Rules"
horizontal_alignment = 1

[node name="HSeparator" type="HSeparator" parent="Panel/VBox"]
layout_mode = 2

[node name="Body" type="RichTextLabel" parent="Panel/VBox"]
layout_mode = 2
size_flags_vertical = 3
theme_override_font_sizes/normal_font_size = 22
bbcode_enabled = true
text = "[ul]
[b]Weekly Income:[/b] You receive [color=green]$150[/color] every week.

[b]Budgets:[/b] Set limits for Food & Vet to control spending. Budgets reset every 7 days.

[b]Emergency Savings:[/b] Start with $200. This fund is used [b]automatically[/b] if you can't afford essential items (Food/Vet).

[color=yellow]Warning:[/color] Relying on savings is risky! Keep a buffer for real emergencies.
[/ul]"

[node name="CloseBtn" type="Button" parent="Panel/VBox"]
custom_minimum_size = Vector2(120, 50)
layout_mode = 2
size_flags_horizontal = 4
theme_override_font_sizes/font_size = 24
text = "Got it!"

[connection signal="pressed" from="Panel/VBox/CloseBtn" to="." method="_on_close_btn_pressed"]
