[gd_scene load_steps=2 format=3 uid="uid://intro123"]

[ext_resource type="Script" path="res://scripts/IntroCutscene.gd" id="1_intro"]

[node name="IntroCutscene" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_intro")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.12, 0.12, 0.14, 1)

[node name="VBoxContainer" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -600.0
offset_top = -200.0
offset_right = 600.0
offset_bottom = 200.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 40
alignment = 1

[node name="Label" type="Label" parent="VBoxContainer"]
custom_minimum_size = Vector2(1200, 0)
layout_mode = 2
theme_override_font_sizes/font_size = 48
text = "Some dogs don’t start life feeling safe."
horizontal_alignment = 1
autowrap_mode = 3

[node name="ContinueButton" type="Button" parent="VBoxContainer"]
visible = false
custom_minimum_size = Vector2(400, 80)
layout_mode = 2
size_flags_horizontal = 4
theme_override_font_sizes/font_size = 40
text = "Continue"

[node name="TechnicalPanel" type="PanelContainer" parent="."]
visible = false
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -800.0
offset_top = -500.0
offset_right = 800.0
offset_bottom = 500.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBoxContainer" type="VBoxContainer" parent="TechnicalPanel"]
layout_mode = 2
theme_override_constants/separation = 20

[node name="Title" type="Label" parent="TechnicalPanel/VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 56
text = "Game Overview"
horizontal_alignment = 1

[node name="Overview" type="Label" parent="TechnicalPanel/VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 32
text = "Welcome to your digital pet care experience! You will adopt a dog, explore a 2D top-down world, and help your pet heal and build trust."
horizontal_alignment = 1
autowrap_mode = 3

[node name="Section1" type="VBoxContainer" parent="TechnicalPanel/VBoxContainer"]
layout_mode = 2

[node name="Header" type="Button" parent="TechnicalPanel/VBoxContainer/Section1"]
custom_minimum_size = Vector2(0, 60)
layout_mode = 2
theme_override_font_sizes/font_size = 32
text = "Stats & Interactions"

[node name="Content" type="Label" parent="TechnicalPanel/VBoxContainer/Section1"]
visible = false
layout_mode = 2
theme_override_font_sizes/font_size = 28
text = "Your dog has stats like Hunger, Energy, Hygiene, Happiness, and Fun that you must manage. Interact through world actions — like walking, playing fetch in the park, visiting the beach, shopping for food and toys, or dropping your pet off at daycare — as well as direct one-on-one care actions like feeding, petting, playing, or washing."
autowrap_mode = 3

[node name="Section2" type="VBoxContainer" parent="TechnicalPanel/VBoxContainer"]
layout_mode = 2

[node name="Header" type="Button" parent="TechnicalPanel/VBoxContainer/Section2"]
custom_minimum_size = Vector2(0, 60)
layout_mode = 2
theme_override_font_sizes/font_size = 32
text = "Care Costs & Budget"

[node name="Content" type="Label" parent="TechnicalPanel/VBoxContainer/Section2"]
visible = false
layout_mode = 2
theme_override_font_sizes/font_size = 28
text = "You will also manage your pet’s care costs, including food, toys, and vet visits, helping you understand responsibility and budgeting."
autowrap_mode = 3

[node name="Section3" type="VBoxContainer" parent="TechnicalPanel/VBoxContainer"]
layout_mode = 2

[node name="Header" type="Button" parent="TechnicalPanel/VBoxContainer/Section3"]
custom_minimum_size = Vector2(0, 60)
layout_mode = 2
theme_override_font_sizes/font_size = 32
text = "Pet Emotions & Growth"

[node name="Content" type="Label" parent="TechnicalPanel/VBoxContainer/Section3"]
visible = false
layout_mode = 2
theme_override_font_sizes/font_size = 28
text = "Your choices affect your pet’s emotions and behavior, and consistent care will help it grow, bond with you, and thrive."
autowrap_mode = 3

[node name="Section4" type="VBoxContainer" parent="TechnicalPanel/VBoxContainer"]
layout_mode = 2

[node name="Header" type="Button" parent="TechnicalPanel/VBoxContainer/Section4"]
custom_minimum_size = Vector2(0, 60)
layout_mode = 2
theme_override_font_sizes/font_size = 32
text = "Customization & Programming Learning"

[node name="Content" type="Label" parent="TechnicalPanel/VBoxContainer/Section4"]
visible = false
layout_mode = 2
theme_override_font_sizes/font_size = 28
text = "Explore, care, and experiment with customization, pet reactions, and interactive features while learning programming concepts such as variables, conditionals, functions, and logic to simulate responsive pet behavior."
autowrap_mode = 3

[connection signal="pressed" from="VBoxContainer/ContinueButton" to="." method="_on_continue_button_pressed"]
